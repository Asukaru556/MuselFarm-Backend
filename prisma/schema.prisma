datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int      @id @default(autoincrement())
  login         String   @unique
  password_hash String
  full_name     String?
  email         String?
  role          String   @default("biologist")
  created_at    DateTime @default(now())

  @@map("users")
}
