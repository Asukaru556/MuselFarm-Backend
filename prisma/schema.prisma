datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int      @id @default(autoincrement())
  login         String   @unique
  password_hash String
  full_name     String?
  email         String?
  role          String   @default("biologist")
  created_at    DateTime @default(now())

  sessions      UserSession[]
  bio_observations BioObservation[]
  operational_events OperationalEvent[]

  @@map("users")
}

model UserSession {
  id                 Int      @id @default(autoincrement())
  user_id            Int
  refresh_token_hash String
  expires_at         DateTime
  created_at         DateTime @default(now())
  ip_address         String?
  user_agent         String?

  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Farm {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  region      String
  description String?
  created_at  DateTime   @default(now())

  locations   Location[]

  @@map("farms")
}

model Location {
  id         Int      @id @default(autoincrement())
  farm_id    Int
  name       String
  latitude   Decimal  @db.Decimal(9, 6)
  longitude  Decimal  @db.Decimal(9, 6)
  depth      Decimal  @db.Decimal(5, 2)
  created_at DateTime @default(now())

  farm       Farm     @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  lines      Line[]

  @@map("locations")
}

model Line {
  id          Int      @id @default(autoincrement())
  location_id Int
  name        String
  depth       Decimal  @db.Decimal(5, 2)
  length      Decimal  @db.Decimal(5, 2)
  status      String   @default("active")
  created_at  DateTime @default(now())

  location    Location @relation(fields: [location_id], references: [id], onDelete: Cascade)
  mussel_batches MusselBatch[]
  sensors        Sensor[]
  measurements Measurement[]
  bio_observations BioObservation[]
  operational_events OperationalEvent[]

  @@map("lines")
}

model MusselBatch {
  id            Int      @id @default(autoincrement())
  line_id       Int
  batch_number  String   @unique
  seed_date     DateTime
  initial_count Int
  status        String   @default("growing")
  created_at    DateTime @default(now())

  line          Line     @relation(fields: [line_id], references: [id], onDelete: Cascade)
  bio_observations BioObservation[]

  @@map("mussel_batches")
}

model Sensor {
  id            Int      @id @default(autoincrement())
  line_id       Int
  name          String
  sensor_type   String   
  serial_number String   @unique
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  line          Line     @relation(fields: [line_id], references: [id], onDelete: Cascade)
  measurements Measurement[]

  @@map("sensors")
}

model Measurement {
  id          Int      @id @default(autoincrement())
  sensor_id   Int
  line_id     Int
  parameter   String   
  value       Decimal  @db.Decimal(10, 4)
  unit        String   
  measured_at DateTime
  created_at  DateTime @default(now())

  sensor      Sensor   @relation(fields: [sensor_id], references: [id], onDelete: Cascade)
  line        Line     @relation(fields: [line_id], references: [id], onDelete: Cascade)

  @@map("measurements")
}

model BioObservation {
  id                Int      @id @default(autoincrement())
  line_id           Int
  batch_id          Int
  fouling_percent   Decimal  @db.Decimal(5, 2)
  mussel_condition  String
  mortality_percent Decimal  @db.Decimal(5, 2)
  density           Int      
  avg_size          Decimal  @db.Decimal(5, 2) 
  avg_weight        Decimal  @db.Decimal(5, 2) 
  pathogen_present  Boolean  @default(false)
  pathogen_type     String?
  comment           String?
  created_by        Int      
  observed_at       DateTime @default(now())

  line              Line         @relation(fields: [line_id], references: [id], onDelete: Cascade)
  batch             MusselBatch  @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("bio_observations")
}

model OperationalEvent {
  id          Int      @id @default(autoincrement())
  line_id     Int
  event_type  String   
  description String
  event_time  DateTime @default(now())
  created_by  Int      

  line        Line     @relation(fields: [line_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("operational_events")
}